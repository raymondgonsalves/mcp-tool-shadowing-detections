# MCP Detection Pack — Forwarder Credentials Template
#
# Copy this file to .env and fill in real values from your Azure setup.
# NEVER commit the real .env file to git. The .gitignore is set up to prevent this.
#
# These values come from the Azure resources created in Day 1 of the project.

# === Entra ID Authentication ===
# From the app registration mcp-forwarder-sp Overview page
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# From Certificates & secrets → Client secrets → Value (only shown once)
AZURE_CLIENT_SECRET=replace_with_real_secret

# === Logs Ingestion Endpoint ===
# From the DCE dce-mcp-detection-lab Overview page → Logs ingestion URL
DCE_INGESTION_URL=https://dce-mcp-detection-lab-XXXX.eastus-1.ingest.monitor.azure.com

# === Data Collection Rule ===
# From the DCR dcr-mcp-detection-lab JSON View → immutableId
DCR_IMMUTABLE_ID=dcr-00000000000000000000000000000000

# The stream name from the DCR's streamDeclarations
DCR_STREAM_NAME=Custom-MCPProtocolLogs_CL
